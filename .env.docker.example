# Docker environment — copy to .env and fill in real values before running docker compose up
# NEVER commit this file with real values filled in

# Database
DB_USERNAME=learnflow
DB_PASSWORD=change_me_strong_password
DB_ROOT_PASSWORD=change_me_root_password

# Laravel app key — generate with: php artisan key:generate --show
APP_KEY=base64:CHANGE_ME

# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=4096

# AI provider (openai | anthropic | gemini | deepseek)
AI_PROVIDER=openai
